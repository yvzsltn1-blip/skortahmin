{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default"
    }
  ],
  "hosting": {
    "site": "aefy-lig",
    "public": ".",
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, max-age=0, must-revalidate"
          },
          {
            "key": "Pragma",
            "value": "no-cache"
          },
          {
            "key": "Expires",
            "value": "0"
          }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "README.md",
      "firestore.rules",
      "firestore.indexes.json",
      "index.backup-*.html",
      "package.json",
      "package-lock.json",
      "capacitor.config.json",
      "scripts/**",
      "functions/**",
      "dist/**",
      "android/**",
      ".apk-toolchain/**",
      "kupa-resim/**",
      "optimize-cups.js",
      "*.apk"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
